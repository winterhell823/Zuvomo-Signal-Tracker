generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Direction {
  BUY
  SELL
}

enum SignalStatus {
  OPEN
  TARGET_HIT
  STOPLOSS_HIT
  EXPIRED
}

model Signal {
  id           String        @id @default(uuid()) @db.Uuid
  symbol       String        @db.VarChar(20)
  direction    Direction
  entryPrice    Decimal       @map("entry_price") @db.Decimal(18, 8)
  stopLoss      Decimal       @map("stop_loss") @db.Decimal(18, 8)
  targetPrice   Decimal       @map("target_price") @db.Decimal(18, 8)
  entryTime     DateTime      @map("entry_time") @db.Timestamp(6)
  expiryTime    DateTime      @map("expiry_time") @db.Timestamp(6)
  status        SignalStatus  @default(OPEN)
  realizedROI   Decimal?      @map("realized_roi") @db.Decimal(18, 8)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("signals")
  @@index([symbol])
  @@index([status])
  @@index([createdAt])
}